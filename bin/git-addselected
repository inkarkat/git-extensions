#!/bin/bash

printUsage()
{
    cat <<HELPTEXT
Interactively select (from modified files or passed list of files) files (or
directly pass N, M, ... selections) to stage by number.
HELPTEXT
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" '[-f|--force] [N [M ...]] [--] [<pathspec>...] [-?|-h|--help]'
}

addCommand='add'
typeset -a selectedCommandArgs=()
typeset -a allargs=()
unset filespecs
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printUsage "$0"; exit 0;;
	--no-color|--color=*)
			shift;;
	--color)	shift; shift;;
	--edit|--patch)	addCommand+=" $1"; shift;;
	--force|-f)	addCommand+=" $1"; shift;;
	--accept-single|--single-only)
			selectedCommandArgs+=("$1"); shift;;
	--filter)	selectedCommandArgs+=("$1" "$2"); shift; shift;;
	--)		shift; typeset -a filespecs=("$@"); set --; break;;
	*)		allargs+=("$1"); shift;;
    esac
done
if [ -z "${filespecs+t}" ]; then
    # No files after -- captured yet; need to investigate parsed and
    # remaining args from behind for files.
    typeset -a filespecs=()
    allargs+=("$@")
    while [ ${#allargs[@]} -ne 0 ]
    do
	lastArg="${allargs[-1]}"
	[ -e "$lastArg" ] || break

	filespecs=("$lastArg" "${filespecs[@]}")
	allargs=("${allargs[@]:0:${#allargs[@]}-1}")
    done
fi
quotedFilespecs=; [ ${#filespecs[@]} -eq 0 ] || printf -v quotedFilespecs '%q ' "${filespecs[@]}"
quotedFilespecs="${quotedFilespecs% }"

export GIT_SELECTED_COMMAND_DEFAULT_FILES="git ls-files --modified -- $quotedFilespecs"
exec git-selected-command "${selectedCommandArgs[@]}" "$addCommand" "${allargs[@]}"	# Note: No root wrapper because ls-files is based off the CWD.
