#!/bin/bash

# I use the translation for these letters:
readonly UPPERCASE_ALIAS_PATTERN='[iy]'

unTranslateUppercaseAlias()
{
    # Translate "-x" to "X" to correctly render aliases with uppercase letters.
    sed -e 's/^\(\[01m[^ ]\+\)-\('"$UPPERCASE_ALIAS_PATTERN"'\)\(.*\[0m\)/\1\u\2\3/'
}

translateUppercaseAlias()
{
    local aliasName="${1?}"; shift
    if [[ "$aliasName" =~ ^[^-].*[[:upper:]] ]]; then
	# Translate "X" to "-x" to enable looking up aliases with uppercase letters.
	aliasName="$(echo "$aliasName" | sed -e 's/[[:upper:]]/-\l\0/g')"
    fi
    printf '%s\n' "$aliasName"
}

printUsage()
{
    cat <<HELPTEXT
List all Git aliases [starting with <pattern>].
HELPTEXT
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" '[<pattern>] [-?|-h|--help]'
}
case "$1" in
    --help|-h|-\?)	shift; printUsage "$0"; exit 0;;
    --no-color|--color=*)
			shift;;
    --color)		shift; shift;;
    --translate)	shift; translateUppercaseAlias "${1?}"; exit 0;;
    --un-translate)	shift; unTranslateUppercaseAlias; exit 0;;
esac
typeset -a pager=("${PAGER:-less}" --RAW-CONTROL-CHARS); [ -t 1 ] || pager=()

printAliases()
{
    local aliasName="$1"
    typeset -a aliasSearchSedArgs=()

    if [ -n "$aliasName" ]; then
	aliasName="$(translateUppercaseAlias "$aliasName")"

	aliasSearchSedArgs=(
	    -e "/^${aliasName}/!d"
	)
    fi

    git config --get-regexp '^alias\.' \
	| sed \
	    -e 's/^alias\.//' \
	    "${aliasSearchSedArgs[@]}" \
	    -e 's/^\([^ ]\+\) /[01m\1[0m = /' \
	| unTranslateUppercaseAlias
}

eval 'printAliases "$@"' \
    "${pager:+|}" '"${pager[@]}"'
