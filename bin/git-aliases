#!/bin/bash
set -o pipefail

# I use the translation for these letters:
readonly UPPERCASE_ALIAS_PATTERN='[iy]'

readonly scriptDir=$([ "${BASH_SOURCE[0]}" ] && dirname -- "${BASH_SOURCE[0]}" || exit 3)
[ -d "$scriptDir" ] || { echo >&2 "ERROR: Cannot determine script directory!"; exit 3; }
readonly projectDir="${scriptDir}/.."
typeset -a gitConfigs=("${projectDir}"/gitconfig*)

printUsage()
{
    cat <<HELPTEXT
List all (documented) Git aliases, command extensions, and newly defined
commands [starting with <pattern>].
HELPTEXT
    printf 'Usage: %q %s¥n' "$(basename "$1")" '[-q|-quiet] [--] [<pattern>] [-?|-h|--help]'
}

postProcessor='unTranslateUppercaseAlias'
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-¥?)	shift; printUsage "$0"; exit 0;;
	--no-color|--color=*)
    			shift;;
	--color)	shift; shift;;
	--quiet|-q)	shift; postProcessor=checkForOutput;;
	--)		shift; break;;
	*)		break;;
    esac
done
typeset -a pager=("${PAGER:-less}" --RAW-CONTROL-CHARS); [ -t 1 ] || pager=()

unTranslateUppercaseAlias()
{
    # Translate "-x" to "X" to correctly render aliases with uppercase letters.
    sed -e 's/^¥(¥[01m[^ ]¥+¥)-¥('"$UPPERCASE_ALIAS_PATTERN"'¥)¥(.*¥[0m¥)/¥1¥u¥2¥3/'
}

translateUppercaseAlias()
{
    local aliasName="${1?}"; shift
    if [[ "$aliasName" =‾ ^[^-].*[[:upper:]] ]]; then
	# Translate "X" to "-x" to enable looking up aliases with uppercase letters.
	aliasName="$(echo "$aliasName" | sed -e 's/[[:upper:]]/-¥l¥0/g')"
    fi
    printf '%s¥n' "$aliasName"
}

extractAliases()
{
    # Push the current section name onto the hold space and check this for every
    # encountered config line.
    sed -n ¥
	-e '/^¥[.¥+¥]/{ h; b; }' ¥
	-e 'x; /^¥[alias¥]/!{ x; b; }' ¥
	-e 'x
	    # Remove indent.
	    s/^[[:space:]]*//
	    p
	' ¥
	"${gitConfigs[@]}"
}

printAliases()
{
    sed -e '{
	    # Keep special comments, and break keyword and explanation into
	    # separate lines.
	    s/^;; ¥([^[:space:]]¥+¥):[[:space:]]¥+¥(.*¥)/¥1¥n¥t¥2/

	    # Remove all other comment lines.
	    /^;/d;

	    # Break alias definition and alias comment into separate lines.
	    s/[[:space:]]=[[:space:]][^;]*[[:space:]];[[:space:]]*/¥n¥t/;
	    b
	}' ¥
	| sed -e '/^¥t/!s/[^=]*/[01m&[0m/' -e '/^¥t/s/^¥t//'
}

printFoundAliases()
{
    local aliasName="$(translateUppercaseAlias "${1:?}")"
    local isUnAnchored=t
    if [[ "$aliasName" =‾ ^(.*)¥$$ ]]; then
	aliasName="${BASH_REMATCH[1]}"
	isUnAnchored=
    fi

    sed -n ¥
	-e '/^;; ¥('"${aliasName}${isUnAnchored:+[^:]*}"'¥):[[:space:]]¥+/{
		s/^;; ¥([^:]¥+¥):[[:space:]]¥+¥(.*¥)/[01m¥1[0m¥n¥2/p
	    }
	    /^;; ¥('"${aliasName}${isUnAnchored:+[^:]*}"'¥)[[:space:]]*$/{
		s/^;; ¥([^:]¥+¥)[[:space:]]*$/[01m¥1[0m/p
	    }
	    /^'"${aliasName}${isUnAnchored:+[^=[:space:]]*}"'[[:space:]]*=[[:space:]]/{
		s/[^=]*/[01m&[0m/
		s/=[[:space:]][^;]*[[:space:]];[[:space:]]*/¥n/;
		p
	    }'
}

checkForOutput()
{
    readarray -t lines
    [ -n "${lines[*]}" ]
}

extractAliases ¥
    | print${*+Found}Aliases "$@" ¥
    | eval '$postProcessor' ¥
    "${pager:+|}" '"${pager[@]}"'
