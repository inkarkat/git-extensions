#!/bin/bash
set -o pipefail
shopt -qs extglob

printUsage()
{
    cat <<HELPTEXT
Interactively select (from staged files or passed list of files) files (or
directly pass N, M, ... selections) and apply the staged changes to the working
copy (when they have been dropped by unapply-index or edited away).
HELPTEXT
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" '[-f|--force] [--ours|--theirs|-m|--merge|--conflict=<style>] [-p|--patch] [N [M ...]] [--] [<pathspec>...] [-?|-h|--help]'
}

typeset -a checkoutArgs=()
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printUsage "$0"; exit 0;;
	--no-color|--color=*)
			shift;;
	--color)	shift; shift;;

	-[fmp])		checkoutArgs+=("$1"); shift;;
	--@(force|ours|theirs|merge|patch))
			checkoutArgs+=("$1"); shift;;
	--conflict)	checkoutArgs+=("$1" "${2?}"); shift; shift;;
	--conflict=*)	checkoutArgs+=("$1"); shift;;
	--)		shift; break;;
	*)		break;;
    esac
done

quotedCheckoutArgs=; [ ${#checkoutArgs[@]} -eq 0 ] || printf -v quotedCheckoutArgs ' %q' "${checkoutArgs[@]}"

GIT_SELECTED_COMMAND_DEFAULT_FILES='git-staged --' exec git-selected-command --filter '' "apply-index$quotedCheckoutArgs" "$@"
