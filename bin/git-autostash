#!/bin/bash
# See https://stackoverflow.com/a/15367176/813602

: ${GIT_AUTOSTASH_COMMAND_JOINER=;}

printShortUsage()
{
    # Note: short followed by long option; if the user knows the short one, she can
    # skim the long one.
    printf 'Usage: %q %s\n' "$(basename "$1")" '[-u|--include-untracked] [--index] [-a|--all] -c|--command "COMMANDLINE" [-c ...] | [--] SIMPLECOMMAND [...] [-?|-h|--help]'
}
printUsage()
{
    # This is the short help when launched with no or incorrect arguments.
    # It is printed to stderr to avoid accidental processing.
    printShortUsage "$1" >&2
    printf >&2 '\nTry %q --help for more information.\n' "$(basename "$1")"
}
printLongUsage()
{
    # This is the long "man page" when launched with the help argument.
    # It is printed to stdout to allow paging with 'more'.
    cat <<HELPDESCRIPTION
Automatically create a temporary stash (of both staged and unstaged changes)
before executing "git SIMPLECOMMAND" and/or COMMANDLINE (which probably contains
Git command(s)), and apply and remove the stash after that operation ends. This
means that you can run Git commands that otherwise would complain on a dirty
worktree.
HELPDESCRIPTION
    echo
    printShortUsage "$1"
    echo
    cat <<HELPTEXT
    --index		Try to reinstate not only the working tree's changes,
			but also the index's ones. However, this can fail when
			you have conflicts.
HELPTEXT
}

commands=
typeset -a stashSaveArgs=()
typeset -a stashPopArgs=()
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printLongUsage "$0"; exit 0;;
	--no-color|--color=*)
			shift;;
	--color)	shift; shift;;
	--include-untracked|-u|--all|-a) stashSaveArgs+=("$1"); shift;;
	--index)	stashPopArgs+=("$1"); shift;;
	--command|-c)	shift; commands+="${commands:+ $GIT_AUTOSTASH_COMMAND_JOINER }$1"; shift;;
	--)		shift; break;;
	-*)		{ echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2;;
	*)  break;;
    esac
done
readonly gitCommand='git-wrapper'
if [ $# -ne 0 ]; then
    # Combine --command and SIMPLECOMMAND; need to quote SIMPLECOMMAND to
    # undo the effects of eval.
    printf -v quotedSimpleCommand '%q ' "$gitCommand" "$@"
    commands+="${commands:+ $GIT_AUTOSTASH_COMMAND_JOINER }${quotedSimpleCommand% }"
fi
if [ -z "$commands" ]; then
    echo 'ERROR: No COMMAND(s) specified; need to pass -c|--command "COMMANDLINE", or SIMPLECOMMAND.'
    echo
    printUsage "$0"
    exit 2
fi >&2

isDirty=; git-isnonemptyrepo && git-dirty --quiet && isDirty=t

if [ "$isDirty" ]; then
    # Emulate the output of git pull --autostash:
    # > Created autostash: db23d8b
    # > HEAD is now at 4166659 Merge branch 'newbr'
    # [COMMANDLINE] output
    # > Applied autostash.
    # The default stash output is too verbose; not showing anything would be
    # confusing, too.
    stashOutput=$(git stash save "${stashSaveArgs[@]}" 'autostash') || exit $!
    printf 'Created autostash: %s\n' "$(git rev-parse --short stash@{0} 2>/dev/null || echo "???")"
    printf '%s\n' "$stashOutput" | sed -e '/^Saved working directory and index state /d'
fi
finally()
{
    if [ "$isDirty" ]; then
	git stash pop --quiet "${stashPopArgs[@]}" && echo "Applied autostash." || exit $?
    fi
    exit $status
}
trap 'finally' EXIT


(eval "$commands"); status=$?
