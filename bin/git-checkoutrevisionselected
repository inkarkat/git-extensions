#!/bin/bash

printUsage()
{
    cat <<HELPTEXT
Interactively select (from files touched in <commit> / HEAD) files (or directly
pass N, M, ... selections) to be reverted to what the content in (with
--previous commit prior to the) passed <commit> was.
HELPTEXT
    printf 'Usage: %q %s\n' "$(basename "$1")" "[--previous] [-f|--force] [--accept-single|--single-only] [--filter ''|FILTER] ([-r|--revision] <commit>) [N [M ...]] [--] [<pathspec>...] [-?|-h|--help]"
}

rev=
checkoutrevisionCommand='checkoutrevision'
typeset -a selectedCommandArgs=()
typeset -a allargs=()
unset filespecs
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printUsage "$0"; exit 0;;
	--no-color|--color=*)
			shift;;
	--color)	shift; shift;;

	--previous|--force|-f)
			checkoutrevisionCommand+=" $1"; shift;;
	--revision|-r)	shift; rev="${1:?}"; shift;;
	--accept-single|--single-only)
			selectedCommandArgs+=("$1"); shift;;
	--filter)	selectedCommandArgs+=("$1" "$2"); shift; shift;;
	--)		shift; typeset -a filespecs=("$@"); set --; break;;
	*)		if [ -z "$rev" ] && rev="$(git-commitid --no-error -- "$1")"; then
			    :
			else
			    allargs+=("$1")
			fi
			shift
			;;
    esac
done
if [ -z "${filespecs+t}" ]; then
    # No files after -- captured yet; need to investigate parsed and
    # remaining args from behind for files.
    typeset -a filespecs=()
    allargs+=("$@")
    while [ ${#allargs[@]} -ne 0 ]
    do
	lastArg="${allargs[-1]}"
	[ -e "$lastArg" ] || break

	filespecs=("$lastArg" "${filespecs[@]}")
	allargs=("${allargs[@]:0:${#allargs[@]}-1}")
    done
fi
quotedFilespecs=; [ ${#filespecs[@]} -eq 0 ] || printf -v quotedFilespecs '%q ' "${filespecs[@]}"
quotedFilespecs="${quotedFilespecs% }"

printf -v quotedRev '%q' "${rev:-HEAD}"
export GIT_SELECTED_COMMAND_DEFAULT_FILES="git-showfiles $quotedRev -- $quotedFilespecs"
exec git-selected-command "${selectedCommandArgs[@]}" "$checkoutrevisionCommand --revision $quotedRev -- $quotedFilespecs" "${allargs[@]}"
