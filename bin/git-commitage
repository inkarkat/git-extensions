#!/bin/bash
shopt -qs extglob

wrappedDatediff()
{
    DATEDIFF_COMMAND="$(basename "$0")" \
    DATEDIFF_WHAT='the age (time of commit) of HEAD / the commits in the passed range' \
    DATEDIFF_INPUT_ARGS='[-v|--with-revision] [--] FILE [...]' \
    DATEDIFF_ADDITIONAL_OPTIONS='    --with-revision|-v	Append a tab and the commit hash and subject to each line.
' \
    DATEDIFF_ADDITIONAL_EXIT_STATUS='    4	The passed <revision-range> / <pathspec> did not yield any commits.' \
    exec datediff "$@"
}

printUsage()
{
    wrappedDatediff --print-usage >&2
}

typeset -a datediffArgs=()
typeset -a datediffOutputArgs=()
formatAddendum=
typeset -a logArgs=()
typeset -a revisions=()
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	wrappedDatediff "$@";;
	--with-revision|-v)
			shift; formatAddendum=$'\t%h\t%s';;
	--)		logArgs+=("$1"); shift; break;;
	--output|-o)	datediffOutputArgs+=("$1" "${2:?}"); shift; shift;;
	-*)		if argCount=$(datediff --understands "$@"); then
			    while ((argCount-- > 0))
			    do
				datediffArgs+=("$1"); shift
			    done
			elif [ $? -eq 2 ]; then
			    exit 2
			else
			    logArgs+=("$1"); shift
			fi
			;;
	*)		if git rev-parse --verify --quiet "${1:?}" >/dev/null 2>&1; then
			    revisions+=("$1")
			else
			    logArgs+=("$1")
			fi
			shift
			;;
    esac
done
[ ${#revisions[@]} -eq 0 -a ${#logArgs[@]} -eq 0 -a $# -eq 0 ] && revisions=(HEAD)
[ ${#revisions[@]} -eq 0 ] \
    && typeset -a gitCommand=(log) \
    || typeset -a gitCommand=(show --no-patch)
[ -n "$formatAddendum" ] && [ ${#datediffOutputArgs[@]} -eq 0 ] && datediffOutputArgs=(--output whole-units)

commitAges="$(git "${gitCommand[@]}" --pretty="tformat:@%ct${formatAddendum}" "${revisions[@]}" "${logArgs[@]}" "$@")" || exit 4
printf '%s\n' "$commitAges" | wrappedDatediff "${datediffArgs[@]}" "${datediffOutputArgs[@]}" --file=-
