#!/bin/bash
shopt -qs extglob

printUsage()
{
    cat <<HELPTEXT
A set of commands that temporarily restore / revert / stash modifications [for
<pathspec>... in] the working copy and run the passed check COMMAND(s) / default
\$GIT_COMPARE_CHECK_COMMAND / \$GIT_CHECK_COMMAND, and compare that with a run
on the original state of the working copy.
HELPTEXT
    compgen -A command git-compare- | sort | prefix -- '- '
    echo
    printf 'Usage: %q-* %s\n' "$(basename "$1")" "$(compareRuns --get-short-usage '' 2>/dev/null) [--] [<pathspec>...] [-?|-h|--help]"
    echo
    printf 'Usage: GIT_COMPARE_CHECK_COMMAND=CMD|GIT_CHECK_COMMAND=CMD %q-* %s\n' "$(basename "$1")" '...'
    printf 'Usage: %q-* %s\n' "$(basename "$1")" "... -c|--command \"CHECK-COMMANDLINE\" [-c ...] | --exec SIMPLECOMMAND [...] ${COMPARERUNS_EXEC_END:-;} [--exec ...] | [--] SIMPLECOMMAND [...]"
    printf 'Usage: echo CHECK-COMMANDLINES | %q-* %s\n' "$(basename "$1")" "... [--bare|$(runWithPrompt --get-short-usage 2>/dev/null)] - ..."
    printf 'Usage: %q-* %s - <<EOF\n  CHECK-COMMANDLINE\n...\nEOF\n' "$(basename "$1")" '...'
}

typeset -a additionalCompareArgs=()
handleTrailingTextRegexpArg()
{
    local compareCommand="${1:?}"; shift
    if [[ "$compareCommand" =~ (g|changed|touched)$ ]]; then
	# Instruct git-compare-* to handle the trailing text|/regexp/ argument.
	additionalCompareArgs+=(--except-last)
    fi
}

case "$1" in
    --help|-h|-\?)	shift; printUsage "$0"; exit 0;;
    co[rp]?(s)*)	handleTrailingTextRegexpArg "$1"
			export GIT_COMPARECHECKOUTREVISION_COMMAND="$1"
			shift
			exec git-compare-checkoutrevision "${additionalCompareArgs[@]}" "$@"
			;;
			;;
    *)			if type -t -- "git-compare-$1" >/dev/null; then
			    # Dedicated compare command; usually is directly invoked by git-wrapper as a
			    # git-sub-alias.
			    delegate="git-compare-$1"; shift
			    exec "$delegate" "$@"
			elif [[ "$2" = co[rp]s ]] && type -t -- "git-$1" >/dev/null; then
			    # Handle br-variants.
			    handleTrailingTextRegexpArg "$2"
			    export GIT_COMPARECHECKOUTREVISION_COMMAND="$1 $2"
			    shift; shift
			    exec git-compare-checkoutrevision "${additionalCompareArgs[@]}" "$@"
			else
			    command hub compare "$@"
			fi
			;;
esac
