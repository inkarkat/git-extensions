#!/bin/bash

printUsage()
{
    cat <<HELPTEXT
Print the configured length of abbreviated object names. Unlike core.abbrev,
this resolving the automatically determined length.
HELPTEXT
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" '[-?|-h|--help]'
}

case "$1" in
    --help|-h|-\?)	shift; printUsage "$0"; exit 0;;
esac

anyCommit="$(git rev-parse --verify --short HEAD)" || exit 3
printf '%d\n' ${#anyCommit}
