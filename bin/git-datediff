#!/bin/bash
set -o pipefail

printShortUsage()
{
    # Note: short followed by long option; if the user knows the short one, she can
    # skim the long one.
    printf 'Usage: %q %s\n' "$(basename "$1")" "[-v|--verbose|--authored] [-u|--utc|--universal] [-f|--format FORMAT|-d|--diff|$(datediff --get-short-usage)] <revision-range>|--since=<date> [-?|-h|--help]"
}
printUsage()
{
    # This is the short help when launched with no or incorrect arguments.
    # It is printed to stderr to avoid accidental processing.
    printShortUsage "$1" >&2
    printf >&2 '\nTry %q --help for more information.\n' "$(basename "$1")"
}
printLongUsage()
{
    # This is the long "man page" when launched with the help argument.
    # It is printed to stdout to allow paging with 'more'.
    cat <<HELPDESCRIPTION
Show the time range of the commits done in the passed <revision-range>, or
--since=<date>.
HELPDESCRIPTION
    echo
    printShortUsage "$1"
    echo
    cat <<HELPTEXT
    --authored		Use the authored date instead of the commit date.
    --verbose|-v	Show both the commit and authored date, and prefix them
			with "Committed" and "Authored", respectively. If they
			are the same, only one line is printed, prefixed with
			"Committed and authored ".
    --format|-f FORMAT	Use FORMAT as the format string for the date command.
    --diff|-d|DATEDIFF-ARGS ...
			Print / compare the difference between start and end
			dates (through datediff).
    --utc|--universal|-u
			Print Coordinated Universal Time (UTC) instead of local
			time, and defaults the format to ISO 8601 format (with Z
			as the timezone).
HELPTEXT
}

typeset -a dateSigils=(c)
typeset -a dateArgs=()
typeset -A prefixes=()
format=
isDiff=
typeset -a datediffArgs=()
typeset -a logArgs=()
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printLongUsage "$0"; exit 0;;
	--no-color|--color=*)
			shift;;
	--color)	shift; shift;;
	--verbose|-v)	shift; dateSigils=(c a); prefixes=([c]='Committed ' [a]='Authored  ');;
	--authored)	shift; dateSigils=(a);;
	--utc|--universal|-u)
			dateArgs+=("$1"); datediffArgs+=("$1"); shift; : ${format:=%FT%TZ};;
	--format|-f)	shift; format="$1"; shift;;
	--diff|-d)	shift; isDiff=t;;
	--)		shift; break;;
	-*)		if argCount=$(datediff --understands "$@"); then
			    while ((argCount-- > 0))
			    do
				isDiff=t
				datediffArgs+=("$1"); shift
			    done
			elif [ $? -eq 2 ]; then
			    exit 2
			else
			    logArgs+=("$1"); shift
			fi
			;;
	*)		logArgs+=("$1"); shift;;
    esac
done
set -- "${logArgs[@]}" "$@"
if [ $# -eq 0 ]; then
    echo 'ERROR: No <revision-range> passed.'
    echo
    printUsage "$0"
    exit 2
fi >&2

dateFormat()
{
    date "${dateArgs[@]}" --date "${1:?}" ${format:++"$format"}
}


for dateSigil in "${dateSigils[@]}"
do
    IFS=' '
    read -r startDate endDate < <(git log --pretty="tformat:%${dateSigil}t" "$@" | sort --numeric --unique | sed -n -e '1h' -e '${H; x; s/\n/ /; p}')
    if [ -z "$startDate" -o -z "$endDate" ]; then
	echo >&2 'No revisions found'
	exit 1
    elif [ "$isDiff" ]; then
	prefix="${prefixes[$dateSigil]}"
	datediff ${prefix:+--prefix "${prefix}within "} "${datediffArgs[@]}" "@$startDate" "@$endDate"
    else
	printf %s "${prefixes[$dateSigil]}"
	    [ $startDate -eq $endDate ] \
		&& printf '%s' "$(dateFormat "@$startDate")" \
		|| printf '%s until %s' "$(dateFormat "@$startDate")" "$(dateFormat "@$endDate")"
	printf \\n
    fi
done | sed -e '1N' -e '2s/^Committed \([^\n]*\)\nAuthored  \1$/Committed and authored \1/'
