#!/bin/bash

: ${GIT_LGHIGHLIGHT_LG:=lg}
: ${GIT_LGHIGHLIGHTEDCOMMITS_ARGS_MARKER='{}'}
argsMarker="$GIT_LGHIGHLIGHTEDCOMMITS_ARGS_MARKER"; unset GIT_LGHIGHLIGHTEDCOMMITS_ARGS_MARKER

readonly scriptDir="$([ "${BASH_SOURCE[0]}" ] && dirname -- "${BASH_SOURCE[0]}" || exit 3)"
[ -d "$scriptDir" ] || { echo >&2 'ERROR: Cannot determine script directory!'; exit 3; }
readonly projectDir="${scriptDir}/.."
readonly libDir="${projectDir}/lib"
source "${libDir}/logArgParser.sh" || exit 3

printUsage()
{
    cat <<HELPTEXT
git ${GIT_LGHIGHLIGHT_LG}, with passed <commit>(s) highlighted.
With --range-to-last-commit, the range will be ended at the last given commit;
naturally, no log range can then be given.
HELPTEXT
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" '[--range-to-last-commit [--one-more]] [GIT-LOG-ARGUMENTS ...] <commit1> [<commit2> ...] [<revision range>|--range <range> [--range...]] [[--] <pathspec>...] [-?|-h|--help]'
    echo
    cat <<HELPTEXT
git ${GIT_LGHIGHLIGHT_LG}, with commit hashes read from stdin highlighted.
HELPTEXT
    echo
    printf 'Usage: git lh [...] | %q %s\n' "$(basename "$1")" '[--range-to-last-commit [--one-more]] [GIT-LOG-ARGUMENTS ...] - [<revision range>|--range <range> [--range...]] [[--] <pathspec>...] [-?|-h|--help]'
    echo
    cat <<HELPTEXT
git ${GIT_LGHIGHLIGHT_LG}, with commits that result from GIT-LOG-COMMAND (which will be configured
to output just commit hashes) highlighted. That argument and GIT-LOG-ARGUMENTS
${argsMarker:+replace a $argsMarker marker in GIT-LOG-COMMAND or }will be appended.
With --except-last, the last argument will only be passed to GIT-LOG-COMMAND,
but not to git ${GIT_LGHIGHLIGHT_LG}.
HELPTEXT
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" '[--range-to-last-commit [--one-more]] [--except-last] GIT-LOG-COMMAND [GIT-LOG-ARGUMENTS ...] [<revision range>|--range <range> [--range...]] [[--] <pathspec>...]'
}

typeset -a commits=()
readCommits()
{
    shopt -qs lastpipe
    local abbrevLen=$(git-config-abbrevlength)
    # Extract the first hexadecimal number that looks like a commit SHA, and only
    # take the short part. Ignore anything else around it.
    sed -n \
	    -e "s/\\(^\\|[[:space:]]\\)\\([[:xdigit:]]\\{${abbrevLen}\\}\\)[[:xdigit:]]*\\([[:space:]].*\\)\\?$/\\2/" \
	    -e 'T' \
	    -e "s/^.*\\([[:xdigit:]]\\{${abbrevLen}\\}\\)$/\1/p" \
	| readarray -t commits
    shopt -qu lastpipe
}

isRangeToLastCommit=
isOneMore=
typeset -a colorArg=()
typeset -a logArgs=()
typeset -a lastArg=()
typeset -a rangeArgs=()
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printUsage "$0"; exit 0;;
	--no-color|--color=*)	colorArg=("$1"); shift;;
	--color)		colorArg=("$1" "$2"); shift; shift;;

	--range-to-last-commit)
			shift; isRangeToLastCommit=t;;
	--one-more)	shift; isOneMore=t;;
	--except-last)	shift
			if [ $# -gt 0 ]; then
			    lastArg=("${!#}")
			    set -- "${@:1:$(($#-1))}"
			fi
			;;
	--range)	shift; rangeArgs+=("${1:?}"); shift;;
	-)		shift
			readCommits
			[ ${#commits[@]} -gt 0 ] || exit 1
			;;
	*)		if argCount=$(countLogArgs t "$1"); then
			    while ((argCount-- > 0))
			    do
				logArgs+=("$1")
				shift
			    done
			else
			    break
			fi
			;;
    esac
done
if [ $# -eq 0 -a ${#commits[@]} -eq 0 ]; then
    echo 'ERROR: No <commit> / - / GIT-LOG-COMMAND passed.'
    echo
    printUsage "$0"
    exit 2
fi >&2

if [ ${#commits[@]} -eq 0 ]; then
    while commit="$(git rev-parse --short "$1" 2>/dev/null)"
    do
	shift
	commits+=("$commit")
    done
fi
if [ ${#commits[@]} -eq 0 ]; then
    gitCommand="${1:?}"; shift

    typeset -a gitCommandArgs=(--pretty=tformat:%h "${logArgs[@]}" "${rangeArgs[@]}" "$@" "${lastArg[@]}")
    printf -v quotedGitCommandArgs '%q ' "${gitCommandArgs[@]}"; quotedGitCommandArgs="${quotedGitCommandArgs% }"
    interpolatedGitCommand="${gitCommand//"$argsMarker"/$quotedGitCommandArgs}"
    [ "$interpolatedGitCommand" = "$gitCommand" ] || gitCommandArgs=()

    readarray -t commits < <(eval "git-wrapper $interpolatedGitCommand" '"${gitCommandArgs[@]}"')
    if [ ${#commits[@]} -eq 0 ]; then
	echo >&2 'No commits found.'
	exit 1
    fi
fi

if [ "$isRangeToLastCommit" ]; then
    set -- "${commits[-1]}^${isOneMore:+^}".. "$@"
fi

IFS=' '
concatenatedCommits="${commits[*]}"
concatenatedCommitsPattern="^\\([ |/\\*]\\|\\x1b\\[[0-9:;]*m\\)\\+ \\(\\x1b\[[0-9:;]*m\\)*\\(${concatenatedCommits// /\\|}\\)\\(\\x1b\\[[0-9:;]*m\\)* "

GIT_LGHIGHLIGHT_RAW_PATTERN=t exec git-lghighlight --grep "$concatenatedCommitsPattern" "${colorArg[@]}" "${logArgs[@]}" "${rangeArgs[@]}" "$@"
