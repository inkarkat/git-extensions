#!/bin/bash

printUsage()
{
    cat <<HELPTEXT
Show commit logs.
HELPTEXT
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" '[<options>] [<revision range>] [[--] <pathspec>...] [-?|-h|--help]'
}

typeset -a allargs=()
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printUsage "$0"; exit 0;;
	-v)		shift; allargs+=('--name-status');;
	--)		allargs+=("$1"); shift; break;;
	*)		allargs+=("$1"); shift;;
    esac
done

exec git log --decorate --topo-order "${allargs[@]}" "$@"
