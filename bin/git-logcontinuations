#!/bin/bash

GIT_CORRECT_REFERENCE_MESSAGE='This continues commit' \
GIT_CORRECT_REFERENCE_REFERRER_PREFIX='' \
GIT_CORRECT_REFERENCE_REFERRER_SUFFIX='continued' \
GIT_LOGCORRECTIONS=$(basename -- "${BASH_SOURCE[0]}") \
GIT_LOGCORRECTIONS_WHAT='continue' \
GIT_LOGCORRECTIONS_SEE_ALSO='git-commitcontinue' \
GIT_LOGCORRECTIONS_SEE_ALSO_WHAT='continuation' \
exec git-logcorrections "$@"

