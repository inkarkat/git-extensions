#!/bin/bash
set -o pipefail

: ${GIT_CORRECT_REFERENCE_MESSAGE:=This corrects commit}
: ${GIT_CORRECT_REFERENCE_REFERRER_PREFIX=after}
: ${GIT_CORRECT_REFERENCE_REFERRER_SUFFIX=}

readonly scriptDir="$([ "${BASH_SOURCE[0]}" ] && dirname -- "${BASH_SOURCE[0]}" || exit 3)"
[ -d "$scriptDir" ] || { echo >&2 'ERROR: Cannot determine script directory!'; exit 3; }
readonly projectDir="${scriptDir}/.."
readonly libDir="${projectDir}/lib"
source "${libDir}/logArgParser.sh" || exit 3

printShortUsage()
{
    # Note: short followed by long option; if the user knows the short one, they can
    # skim the long one.
    printf 'Usage: %q %s\n' "$(basename "$1")" '[--first-chain|--follow-chains] [--local-only] [LOG-ARGS ...] [<revision range>] [[--] <pathspec>...] [-?|-h|--help]'
}
printUsage()
{
    # This is the short help when launched with no or incorrect arguments.
    # It is printed to stderr to avoid accidental processing.
    printShortUsage "$1" >&2
    printf >&2 '\nTry %q --help for more information.\n' "$(basename "$1")"
}
printLongUsage()
{
    # This is the long "man page" when launched with the help argument.
    # It is printed to stdout to allow paging with 'more'.
    cat <<HELPDESCRIPTION
Show commit logs of commits that correct / reference previous revision(s) (when
it's too late or cumbersome to fixup / amend the existing commit).
This checks for references to the prior commit(s) in the commit message (title
and body, hexadecimal syntax only; no configured tag references in the title).
HELPDESCRIPTION
    echo
    printShortUsage "$1"
    echo
    cat <<HELPTEXT
    --first-chain	Only follow the first encountered commit that corrects
			or references previous revision(s) and include the
			commit(s) that are referenced in the commit message(s),
			too.
    --follow-chains	Include the commit(s) that are referenced in the commit
			message(s), too.
    --local-only	Omit commits that reference another repository.

SEE ALSO:
- (Commands offering complementary functionality, or commands using this command.)

RELATED COMMANDS:
- (Alternatives from other authors, other approaches, references not used here.)

cla-exitstatus

Example:
HELPTEXT
    printf '%q %s\n' "$(basename "$1")" '--foo bar /tmp/foobar' # TODO
}

action=logCorrections
chainSource=logCorrectionsAndReferences
isAllowRemoteReferences=t
typeset -a gitPrettyArg=()
typeset -a logArgs=()
typeset -a logOutputArgs=()
typeset -a logGeneralArgs=()
typeset -a logRange=()
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printLongUsage "$0"; exit 0;;
	--first-chain)	chainSource=logSingleCorrectionAndChain;&
	--follow-chains)
			shift; action=logCorrectionsAndChain
			if [ -n "$GIT_LOGCORRECTIONS_COMMAND" ]; then
			    # Workaround: git-logrevs passes all revisions to a Git command with "git show"
			    # semantics, but the customization here asks for a command with "git log"
			    # semantics. Convert by invoking it for each revision separately (keeping any
			    # command-line options (that git-logrevs itself passes)) while limiting the
			    # scope to a single commit.
			    export GIT_LOGREVS_SHOW_COMMAND="exec eachArg --trailing-argument-match-exec git rev-parse --verify --quiet ; git-wrapper $GIT_LOGCORRECTIONS_COMMAND --max-count 1"
			fi
			GIT_LOGCORRECTIONS_COMMAND=log
			;;
	--local-only)	shift; isAllowRemoteReferences=;;
	--pretty=*)	gitPrettyArg=("$1"); shift;;
	--)		logArgs+=("$1"); shift; break;;
	*)		if argCount=$(countLogArgsInfluencingOutput "$1") \
			    || argCount=$(countDiffArgs "$1")
			then
			    while ((argCount-- > 0))
			    do
				logOutputArgs+=("$1")
				shift
			    done
			elif argCount=$(countLogArgs '' "$1"); then
			    while ((argCount-- > 0))
			    do
				logGeneralArgs+=("$1")
				shift
			    done
			elif [ -n "$(git rev-parse --revs-only "$1" 2>/dev/null)" ]; then
			    logRange+=("$1")
			    shift
			else
			    logArgs+=("$1")
			    shift
			fi
			;;
    esac
done
remoteReferencePattern="${isAllowRemoteReferences:+\\([^ ]\\+@\\)\\?}"
titleReferencePattern="\\(${remoteReferencePattern}[[:xdigit:]]\\+\\)"; titleReferencePattern="${titleReferencePattern}\\(, ${titleReferencePattern}\\)*"
bodyReferencePattern="${remoteReferencePattern}[[:xdigit:]]\\+\\(\\(,\\| and\\) ${remoteReferencePattern}[[:xdigit:]]\\+\\)*"
typeset -a grepArgs=(
    " (${GIT_CORRECT_REFERENCE_REFERRER_PREFIX}${GIT_CORRECT_REFERENCE_REFERRER_PREFIX:+ }\\(${titleReferencePattern}\\)${GIT_CORRECT_REFERENCE_REFERRER_SUFFIX:+ }${GIT_CORRECT_REFERENCE_REFERRER_SUFFIX})\$" \
    "^(${GIT_CORRECT_REFERENCE_MESSAGE} ${bodyReferencePattern})\$" \
)

logSource()
{
    git-wrapper ${GIT_LOGCORRECTIONS_COMMAND:-log} "${grepArgs[@]/#/--grep=}" "$@"
}

logCorrections()
{
    logSource "${gitPrettyArg[@]}" "${logGeneralArgs[@]}" "${logOutputArgs[@]}" "${logRange[@]}" "$@"
}

extractReferences()
{
    sed \
	-e 's/^commit //' \
	-e "s/^ (${GIT_CORRECT_REFERENCE_REFERRER_PREFIX}${GIT_CORRECT_REFERENCE_REFERRER_PREFIX:+ }//" \
	-e "s/${GIT_CORRECT_REFERENCE_REFERRER_SUFFIX:+ }${GIT_CORRECT_REFERENCE_REFERRER_SUFFIX})\$//" \
	-e "s/^(${GIT_CORRECT_REFERENCE_MESSAGE} //" \
	-e "s/)\$//" \
	-e 's/, \| and /\n/g'
}

logCorrectionsAndReferences()
{
    logSource --pretty=tformat:'commit %H%n%B' "${logGeneralArgs[@]}" "${logRange[@]}" "$@" \
	| grep --only-matching -e '^commit [[:xdigit:]]\+$' "${grepArgs[@]/#/--regexp=}" \
	| extractReferences
}

logSingleCorrectionAndChain()
{
    {
	# First line is the correction commit, the following lines are the references
	# (if any).
	read -r correctionCommit
	[ -n "$correctionCommit" ] || return 0

	typeset -a references=(); readarray -t references
	case ",${DEBUG:-}," in *,git-logcorrections:recursion,*) printf >&2 '%sgit-logcorrections (recursion): %s references %s\n' "$PS5" "$correctionCommit" "$(joinBy --empty 'nothing' ', ' "${references[@]}")";; esac

	printf '%s\n' "$correctionCommit"
	local ref; for ref in "${references[@]}"
	do
	    # Recurse for each reference.
	    logRange=("$ref")
	    logSingleCorrectionAndChain "$@"

	    # Include the reference itself, too (to include leaf nodes that don't reference
	    # any other commit).
	    printf '%s\n' "$ref"
	done
    } < <(
	    # Optimization: Filter out duplicate references, also of varying lengths.
	    logCorrectionsAndReferences --max-count 1 "${logRange[@]}" "$@" \
		| firstRestLines --rest-command uniquePrefixes
	)
}

logCorrectionsAndChain()
{
    $chainSource "$@" \
	| git-logrevs "${gitPrettyArg[@]}" "${logOutputArgs[@]}"
}

$action "${logArgs[@]}" "$@"
