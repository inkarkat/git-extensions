#!/bin/bash
set -o pipefail
shopt -qs extglob

: ${GIT_CORRECT_REFERENCE_MESSAGE:=This corrects commit}
: ${GIT_CORRECT_REFERENCE_REFERRER_PREFIX=after}
: ${GIT_CORRECT_REFERENCE_REFERRER_SUFFIX=}

: ${GIT_LOGCORRECTIONS_REMOTE_WORKINGCOPY_LOOKUP_COMMAND="sh -c 'zd --best-match \${1##*/}' sh"}
gitLogCorrectionsCommand="${GIT_LOGCORRECTIONS_COMMAND:-log}"

readonly scriptDir="$([ "${BASH_SOURCE[0]}" ] && dirname -- "${BASH_SOURCE[0]}" || exit 3)"
[ -d "$scriptDir" ] || { echo >&2 'ERROR: Cannot determine script directory!'; exit 3; }
readonly projectDir="${scriptDir}/.."
readonly libDir="${projectDir}/lib"
source "${libDir}/logArgParser.sh" || exit 3
readonly scriptName="$(basename -- "${BASH_SOURCE[0]}")"

printShortUsage()
{
    # Note: short followed by long option; if the user knows the short one, they can
    # skim the long one.
    printf 'Usage: %q %s\n' "${GIT_LOGCORRECTIONS:-$(basename "$1")}" '[-f|--follow-first-chain|-i|--include-references] [-l|--local-only] [LOG-ARGS ...] [<revision range>] [[--] <pathspec>...] [-?|-h|--help]'
}
printUsage()
{
    # This is the short help when launched with no or incorrect arguments.
    # It is printed to stderr to avoid accidental processing.
    printShortUsage "$1" >&2
    printf >&2 '\nTry %q --help for more information.\n' "${GIT_LOGCORRECTIONS:-$(basename "$1")}"
}
printLongUsage()
{
    # This is the long "man page" when launched with the help argument.
    # It is printed to stdout to allow paging with 'more'.
    cat <<HELPDESCRIPTION
Show commit logs of commits that ${GIT_LOGCORRECTIONS_WHAT:-correct} / reference previous revision(s)
(when it's too late or cumbersome to fixup / amend the existing commit) by
looking for references to the prior commit(s) in the commit message (title and
body, hexadecimal syntax only; no configured tag references in the title).
This shows you which commits actively reference other commits (without showing
those).
HELPDESCRIPTION
    echo
    printShortUsage "$1"
    echo
    cat <<HELPTEXT
    --follow-first-chain|-f
			Stop after encountering the first commit that corrects
			or references previous revision(s), but include those
			commit(s) that are referenced in the commit message(s),
			and follow those references recursively, too.
			This gives you a full picture of the web of corrections
			and references, and is therefore limited to a single
			root commit.
    --include-references|-i
			Include the commit(s) that are referenced in the commit
			message(s), too (but don't follow them any further).
			This shows you which commits reference and are
			referenced by reachable commits / the passed revision
			range.
    --local-only|-l	Omit commits that reference another repository. Only
			list commits that reference at least one commit in the
			same repository. Don't follow references to other
			repositories, either.

SEE ALSO:
- ${GIT_LOGCORRECTIONS_SEE_ALSO:-git-correct} can be used to create a commit as a ${GIT_LOGCORRECTIONS_SEE_ALSO_WHAT:-correction} of
  previous revision(s).

EXIT STATUS:
    0	Complete success.
    1	Failed to log.
    2	Bad invocation, wrong or missing command-line arguments.
    3	Internal error or failed assertion.
HELPTEXT
}

resolveRemoteDirspec()
{
    if [ -n "$GIT_LOGCORRECTIONS_REMOTE_WORKINGCOPY_LOOKUP_COMMAND" ]; then
	eval "$GIT_LOGCORRECTIONS_REMOTE_WORKINGCOPY_LOOKUP_COMMAND" "$remote" 2>/dev/null
    else
	printf %s "../${remote##*/}"
    fi
}

isInRecursion=
action=logCorrections
chainSource=logCorrectionsAndReferences
isAllowRemoteReferences=t
typeset -a gitPrettyArg=()
typeset -a logArgs=()
typeset -a logOutputArgs=()
typeset -a logGeneralArgs=()
typeset -a logRange=()
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printLongUsage "$0"; exit 0;;

	--remote-log)	shift
			status=0
			while IFS='@' read -r remote remoteReference
			do
			    remoteDirspec="$(resolveRemoteDirspec "$remote")"
			    if [ -d "$remoteDirspec" ]; then
				{
				    printf '%s: ' "$remote"
				    git-inside ${GIT_LOGCORRECTIONS_COMMAND:-log} "$@" --max-count 1 "$remoteReference" -- "$remoteDirspec"
				} | padding --multiple-lines --after '' \
				    || status=$?
			    else
				printf '\n%s@%s (working copy not available)\n' "$remote" "$remoteReference"
			    fi
			done
			exit $status
			;;

	--remote-follow)
			shift
			isInRecursion=t
			remote="${1:?}"; shift
			logRange=("${1:?}"); shift
			chainSource=logSingleCorrectionAndChain
			action=logCorrectionsAndChain
			gitPrettyArg=(--pretty=tformat:"${remote}@%H%n")    # Note: Include an empty separator line so that the caller doesn't do the uniquePrefixes filtering that would scramble the order of the commits. The deduplication of references has already been done by the callee, anyway.
			;;

	--follow-first-chain|-f)
			chainSource=logSingleCorrectionAndChain;&
	--include-references|-i)
			shift; action=logCorrectionsAndChain
			if [ -n "$GIT_LOGCORRECTIONS_COMMAND" ]; then
			    # Workaround: git-logrevs passes all revisions to a Git command with "git show"
			    # semantics, but the customization here asks for a command with "git log"
			    # semantics. Convert by invoking it for each revision separately (keeping any
			    # command-line options (that git-logrevs itself passes)) while limiting the
			    # scope to a single commit.
			    export GIT_LOGREVS_SHOW_COMMAND="exec eachArg --trailing-argument-match-exec git rev-parse --verify --quiet ; git-wrapper $gitLogCorrectionsCommand --max-count 1"
			fi
			gitLogCorrectionsCommand=log
			;;
	--local-only|-l)
			shift; isAllowRemoteReferences=;;
	--pretty=*)	gitPrettyArg=("$1"); shift;;
	--)		logArgs+=("$1"); shift; break;;
	*)		if argCount=$(countLogArgsInfluencingOutput "$1") \
			    || argCount=$(countDiffArgs "$1")
			then
			    while ((argCount-- > 0))
			    do
				logOutputArgs+=("$1")
				shift
			    done
			elif argCount=$(countLogArgs '' "$1"); then
			    while ((argCount-- > 0))
			    do
				logGeneralArgs+=("$1")
				shift
			    done
			elif [ -n "$(git rev-parse --revs-only "$1" 2>/dev/null)" ]; then
			    logRange+=("$1")
			    shift
			else
			    logArgs+=("$1")
			    shift
			fi
			;;
    esac
done
remoteReferencePattern="${isAllowRemoteReferences:+\\([^ ]\\+@\\)\\?}"
titleReferencePattern="\\(${remoteReferencePattern}[[:xdigit:]]\\+\\)"; titleReferencePattern="${titleReferencePattern}\\(, ${titleReferencePattern}\\)*"
bodyReferencePattern="${remoteReferencePattern}[[:xdigit:]]\\+\\(\\(,\\| and\\) ${remoteReferencePattern}[[:xdigit:]]\\+\\)*"
typeset -a grepArgs=(
    " (${GIT_CORRECT_REFERENCE_REFERRER_PREFIX}${GIT_CORRECT_REFERENCE_REFERRER_PREFIX:+ }\\(${titleReferencePattern}\\)${GIT_CORRECT_REFERENCE_REFERRER_SUFFIX:+ }${GIT_CORRECT_REFERENCE_REFERRER_SUFFIX})\$" \
    "^(${GIT_CORRECT_REFERENCE_MESSAGE} ${bodyReferencePattern})\$" \
)

if [ "$isAllowRemoteReferences" ] && [ ! "$isInRecursion" ]; then
    # A remote reference may refer back to the original repository where the command
    # was launched in. We want to handle those like local references, so we need to
    # know our own user repository name to recognize those references.
    startingUserRepo="$(hub-userrepo --fallback-guess 2>/dev/null)"
fi

logSource()
{
    git-wrapper $gitLogCorrectionsCommand "${grepArgs[@]/#/--grep=}" "$@"
}

logCorrections()
{
    logSource "${gitPrettyArg[@]}" "${logGeneralArgs[@]}" "${logOutputArgs[@]}" "${logRange[@]}" "$@"
}

extractReferences()
{
    sed \
	-e 's/^commit //' \
	-e "s/^ (${GIT_CORRECT_REFERENCE_REFERRER_PREFIX}${GIT_CORRECT_REFERENCE_REFERRER_PREFIX:+ }//" \
	-e "s/${GIT_CORRECT_REFERENCE_REFERRER_SUFFIX:+ }${GIT_CORRECT_REFERENCE_REFERRER_SUFFIX})\$//" \
	-e "s/^(${GIT_CORRECT_REFERENCE_MESSAGE} //" \
	-e "s/)\$//" \
	-e 's/, \| and /\n/g'
}

logCorrectionsAndReferences()
{
    logSource --pretty=tformat:'commit %H%n%B' "${logGeneralArgs[@]}" "${logRange[@]}" "$@" \
	| grep --only-matching -e '^commit [[:xdigit:]]\+$' "${grepArgs[@]/#/--regexp=}" \
	| extractReferences
}

logSingleCorrectionAndChain()
{
    {
	# First line is the correction commit, the following lines are the references
	# (if any).
	read -r correctionCommit
	[ -n "$correctionCommit" ] || return 0

	typeset -a references=(); readarray -t references
	case ",${DEBUG:-}," in *,git-logcorrections:recursion,*) printf >&2 '%sgit-logcorrections (recursion): %s references %s\n' "$PS5" "$correctionCommit" "$(joinBy --empty 'nothing' ', ' "${references[@]}")";; esac

	printf '%s\n' "$correctionCommit"
	local ref; for ref in "${references[@]}"
	do
	    # Include the reference itself, too (to include leaf nodes that don't reference
	    # any other commit).
	    printf '%s\n' "$ref"

	    # Recurse for each reference.
	    if [[ "$ref" = +([^ ])@+([[:xdigit:]]) ]]; then
		IFS='@' read -r remote remoteReference <<<"$ref"; shift
		remoteDirspec="$(resolveRemoteDirspec "$remote")"
		if [ -d "$remoteDirspec" ]; then
		    # Recurse for the remote reference (through recursive invocation inside that
		    # working copy).
		    git-inside "${scriptName#git-}" --remote-follow "$remote" "$remoteReference" "$remoteDirspec"
		else
		    printf >&2 'Note: Working copy for %s@%s not available; skipping.\n' "$remote" "$remoteReference"
		fi
	    else
		# Recurse for the local reference (through $logRange).
		logRange=("$ref")
		logSingleCorrectionAndChain "$@"
	    fi
	done
    } < <(
	    # Optimization: Filter out duplicate references, also of varying lengths.
	    logCorrectionsAndReferences --max-count 1 "$@" \
		| firstRestLines --rest-command uniquePrefixes
	)
}

logCorrectionsAndChain()
{
    # First just collect references, because these are single lines that can be
    # segregated and deduplicated (whereas the final log output has uncontrollable
    # often multi-line output). That may switch to other working copies and recurse
    # in order to follow remote refereces. Only at the end, back at the initial call after
    # the recursions, we render the commits, again switching to other working copies
    # of remote references as needed.
    $chainSource "$@" \
	|   if [ "$isAllowRemoteReferences" ]; then
		typeset -a segregateInputInitialCallArgs=()
		[ "$isInRecursion" ] || segregateInputInitialCallArgs+=(
		    # A remote reference might itself have another remote reference back to the
		    # original repository. We don't want the remote prefix there, and don't need the
		    # whole going to that working copy and invoking the log command there.
		    # Just strip off the remote prefix and handle it as the local reference it is.
		    --regexp-exec "^${startingUserRepo}@[[:xdigit:]]+\$" unprefix -- "${startingUserRepo}@" \;
		    --regexp-exec "^${startingUserRepo}@[[:xdigit:]]+\$" git-logrevs "${gitPrettyArg[@]}" "${logOutputArgs[@]}" \;

		    # Note: Empty lines serve as separators between remote references returned by
		    # the recursive calls, so that there's no uniquePrefixes filtering that would
		    # scramble the order of the commits. We'll swallow them here.
		    --regexp-exec '^$' swallow \; \

		    # Handle remote references through going to that working copy and invoking the
		    # log command there. As this is too involved for a single commandline, we invoke
		    # ourselves for it.
		    --fallback-exec uniquePrefixes \;
		    --fallback-exec "${BASH_SOURCE[0]}" --remote-log "${gitPrettyArg[@]}" "${logOutputArgs[@]}" \;
		)

		# Render references in the current working copy; recursive invocations will just
		# pass through any other input; the initial call will render all those collected
		# remote references.
		segregateInput \
		    --regexp-exec '^[[:xdigit:]]+$' git-logrevs "${gitPrettyArg[@]}" "${logOutputArgs[@]}" \; \
		    "${segregateInputInitialCallArgs[@]}"
	    else
		git-logrevs "${gitPrettyArg[@]}" "${logOutputArgs[@]}"
	    fi
}

$action "${logArgs[@]}" "$@"
