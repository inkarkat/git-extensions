#!/bin/bash

GIT_CORRECT_REFERENCE_MESSAGE='This relates to commit' \
GIT_CORRECT_REFERENCE_REFERRER_PREFIX='cp.' \
GIT_LOGCORRECTIONS=$(basename -- "${BASH_SOURCE[0]}") \
GIT_LOGCORRECTIONS_WHAT='relate to' \
GIT_LOGCORRECTIONS_SEE_ALSO='git-commitrelate' \
GIT_LOGCORRECTIONS_SEE_ALSO_WHAT='relation' \
exec git-logcorrections "$@"
