#!/bin/bash

printUsage()
{
    cat <<HELPTEXT
Test whether there are / list modified (staged and unstaged) files.
HELPTEXT
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" '[-q|--quiet|-E|--print-error [--error-message MSG]] [--] [<pathspec>...] [-?|-h|--help]'
}

isQuiet=
errorMessage='ERROR: Working copy has changes and/or index is not empty:'
isPrintError=
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printUsage "$0"; exit 0;;
	--no-color|--color=*)
			shift;;
	--color)	shift; shift;;
	--quiet|-q)	shift; isQuiet=t;;
	--print-error|-E)
			shift; isPrintError=t;;
	--error-message)
			shift; errorMessage="$1"; shift;;
	--)		shift; break;;
	-*)		{ echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2;;
	*)		break;;
    esac
done

typeset -A stagedFiles=()
while IFS=$'\n' read -r filespec
do
    stagedFiles["$filespec"]=t
done < <(git-stifiles -- "$@")

readarray -t modifiedFiles < <(git-stIfiles HEAD -- "$@")   # Note: "HEAD" includes staged and unstaged changes, but not those where the staged change is undone in the working copy.
# Note: I could also use { git-stifiles; git-stIfiles; } | sort -u, but that
# requires another external command unconditionally.

if [ ${#stagedFiles[@]} -gt 0 ]; then
    for filespec in "${modifiedFiles[@]}"
    do
	unset "stagedFiles[$filespec]"
    done
fi

if [ ${#modifiedFiles[@]} -gt 0 -o ${#stagedFiles[@]} -gt 0 ]; then
    [ ! "$isQuiet" ] || exit 0
    [ ! "$isPrintError" ] || printf >&2 '%s\n' "$errorMessage"
    if [ ${#stagedFiles[@]} -eq 0 ]; then
	printf '%s\n' "${modifiedFiles[@]}"
    else
	# Some file(s) are staged, but the change is undone in the working copy,
	# so it's not contained in $modifiedFiles. We need to combine both
	# lists.
	printf '%s\n' "${modifiedFiles[@]}" "${!stagedFiles[@]}" | sort
    fi
    [ ! "$isPrintError" ] || exit 1
else
    [ "$isPrintError" ] || exit 1
fi
