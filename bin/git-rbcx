#!/bin/bash

printUsage()
{
    cat <<HELPTEXT
addcx + rbc: Stage files with resolved conflicts and continue rebasing.
HELPTEXT
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" '[--] [<pathspec>...] [-?|-h|--help]'
}

case "$1" in
    --help|-h|-\?)	shift; printUsage "$0"; exit 0;;
    --no-color|--color=*)
			shift;;
    --color)		shift; shift;;
esac

git addconflicts "$@" \
    && git-wrapper ${GIT_RBCX_REBASE_CONFIG:+-c "$GIT_RBCX_REBASE_CONFIG"} rebase --continue
