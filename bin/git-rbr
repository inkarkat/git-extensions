#!/bin/bash
set -o pipefail
shopt -qs extglob

filterAge()
{
    datediff --field-separator $'\t' "$@"
}

printShortUsage()
{
    # Note: short followed by long option; if the user knows the short one, she can
    # skim the long one.
    printf 'Usage: %q %s\n' "$(basename "$1")" "${remote:-REMOTE|''} [$(filterAge --get-short-usage filter 2>/dev/null)] [--sort <key> [--sort ...]] [--] [<branch-glob> ...] [-?|-h|--help]"
}
printUsage()
{
    # This is the short help when launched with no or incorrect arguments.
    # It is printed to stderr to avoid accidental processing.
    printShortUsage "$1" >&2
    printf >&2 '\nTry %q --help for more information.\n' "$(basename "$1")"
}
printLongUsage()
{
    # This is the long "man page" when launched with the help argument.
    # It is printed to stdout to allow paging with 'more'.
    cat <<HELPDESCRIPTION
List all branches in ${remote:-REMOTE / all remotes} [matching <branch-glob>].
HELPDESCRIPTION
    echo
    printShortUsage "$1"
    echo
    filterAge --get-long-usage filter 'branches' 2>/dev/null
    cat <<HELPTEXT
    <branch-glob>	Only consider branches that match <branch-glob>.
HELPTEXT
}

case "$1" in
    --help|-h|-\?)	shift; printLongUsage "$0"; exit 0;;
    --no-color|--color=*)
			shift;;
    --color)		shift; shift;;
esac

if [ $# -eq 0 ]; then
    echo >&2 'ERROR: Must pass REMOTE.'
    exit 2
fi
remote="${1:?}"; shift

typeset -a branchArgs=()
postProcessingAction=
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printLongUsage "$0"; exit 0;;
	--no-color|--color=*)
			shift;;
	--color)	shift; shift;;
	--@(merged|no-merged|contains|no-contains|points-at|sort))
			branchArgs+=("$1" "$2"); shift; shift;;
	--@(merged|no-merged|contains|no-contains|points-at|sort)=*)
			branchArgs+=("$1"); shift;;
	--)		shift; break;;
	-*)		if argCount=$(filterAge --understand-for filter --understands "$@"); then
			    [ -n "$postProcessingAction" ] || postProcessingAction='augmentLines --prepend -- git log --max-count 1 --pretty=tformat:@%ct | filterAge --filter'
			    while ((argCount-- > 0))
			    do
				printf -v quotedArg ' %q' "$1"
				postProcessingAction+="$quotedArg"; shift
			    done
			elif [ $? -eq 2 ]; then
			    exit 2
			else
			    { echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2
			fi
			;;
	*)		break;;
    esac
done
[ $# -gt 0 ] || set -- '*'

remoteBranchQuery()
{
    git branch "${branchArgs[@]}" --remotes --list --format '%(refname:lstrip=2)' "${@/#/${remote}${remote:+/}}" \
	| sed -e "/^${remote:-[^/]\\+}\/HEAD$/d"
}
eval 'remoteBranchQuery "$@"' \
    "${postProcessingAction:+|}$postProcessingAction"
