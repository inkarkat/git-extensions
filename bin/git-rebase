#!/bin/bash

: ${GIT_REBASE_EXEC_END=;}
: ${GIT_EXTRACTCORECOMMITSUBJECTCOMMAND=extractCoreCommitSubject.sh}

readonly scriptDir="$([ "${BASH_SOURCE[0]}" ] && dirname -- "${BASH_SOURCE[0]}" || exit 3)"
[ -d "$scriptDir" ] || { echo >&2 'ERROR: Cannot determine script directory!'; exit 3; }
readonly projectDir="${scriptDir}/.."
readonly libDir="${projectDir}/lib"
PATH="${libDir}:${PATH}"

printUsage()
{
    cat <<HELPTEXT
Reapply commits on top of another base tip.
Also considers submodules and automatically checks out resulting versions
(unless --no-submodule-update is given).
Supports my command-passing conventions (-c|--command and --exec ... ;, git
SIMPLECOMMAND after --) and running build checks from stdin / preconfigured.
HELPTEXT
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" "[--no-submodule-update] [--no-rebase-checks] [--check|-|-c|-x|--command COMMANDLINE|--exec SIMPLECOMMAND [...] ${GIT_REBASE_EXEC_END} [-c ...]]  [<rebase-args> ...] [-- SIMPLECOMMAND ...] [-?|-h|--help]"
}

addExec()
{
    local isQuoted="${1?}"; shift
    local cmd="${1:?}"; shift

    if [ "$isQuoted" ]; then
	# XXX: Git rebase uses the default shell, which isn't necessarily Bash.
	# It also has a problem of dropping a trailing space when it's
	# backslash-escaped. By converting \n to a literal newline, the following fix
	# will be applied to escaped newlines as well.
	type -t changeQuoting >/dev/null && cmd="$(printf %s "$cmd" | changeQuoting --posix)"
    fi

    # XXX: exec commands cannot contain newlines.
    cmd="${cmd//$'\\\n'/ }"
    cmd="${cmd//$'\n'/; }"

    rebaseArgs+=(--exec "$cmd")
}

gitDir="$(git rev-parse --git-dir 2>/dev/null)" || exit 3
readonly originalPersistentCommitsFilespec="${gitDir}/rebaseOriginalPersistentCommits"
readonly rebasedCommitHashesFilespec="${gitDir}/rebasedCommitHashes"
typeset -ra rebaseDeduplicateLogArgs=(--grep '^\\(fixup\\|amend\\|squash\\)! ' --invert-grep --pretty=$'tformat:%H\t%at\t%aN\t%aE\t%s')
recordOriginalPersistentCommits()
{
    if [ ${#rebaseArgs[@]} -ge 2 ] \
	&& git-commitid --quiet --no-error -- "${rebaseArgs[-1]}" \
	&& git-commitid --quiet --no-error -- "${rebaseArgs[-2]}"
    then
	# <upstream> <branch> variant
	local branch="${rebaseArgs[-1]}"
	local upstream="${rebaseArgs[-2]}"
    else
	local branch=HEAD
	local upstream="${rebaseArgs[-1]}"
    fi
    git log "${rebaseDeduplicateLogArgs[@]}" "${upstream}..${branch}" > "$originalPersistentCommitsFilespec"
}
# Duplicated to /getLenientIdentifyingInformation() git-inout
getLenientIdentifyingInformation()
{
    ${GIT_EXTRACTCORECOMMITSUBJECTCOMMAND:-false} "$@"
}
generateRebasedCommitHashes()
{
    [ -r "$originalPersistentCommitsFilespec" ] || return 1

    typeset -a rebasedPersistentCommitList=()
    typeset -A rebasedPersistentRebasedKeys=() rebasedPersistentReworkedKeys=() rebasedPersistentReworkedLenientKeys=()
    local commit authorEpoch additionalIdentifyingInformation lenientAdditionalIdentifyingInformation
    while IFS=$'\t' read -r commit authorEpoch additionalIdentifyingInformation
    do
	rebasedPersistentCommitList+=("$commit")
	rebasedPersistentRebasedKeys["$commit"]="$authorEpoch"$'\t'"$additionalIdentifyingInformation"
	rebasedPersistentReworkedKeys["$commit"]="$additionalIdentifyingInformation"
	lenientAdditionalIdentifyingInformation="$(getLenientIdentifyingInformation "$additionalIdentifyingInformation")" \
	    && rebasedPersistentReworkedLenientKeys["$commit"]="$lenientAdditionalIdentifyingInformation"
    done < <(eval 'git-rev-range-to-pre-rebase log "${rebaseDeduplicateLogArgs[@]}"' "${DEBUG:+| debugtee --single-capture --for git-rebase --module rebasedCommitHashes --to ${gitDir@Q}/rebaseNewPersistentCommits}")

    [ ${#rebasedPersistentCommitList[@]} -gt 0 ] || return 99

    typeset -A originalPersistentCommits=() originalPersistentRebasedCommits=() originalPersistentReworkedCommits=() originalPersistentReworkedLenientCommits=()
    while IFS=$'\t' read -r commit authorEpoch additionalIdentifyingInformation
    do
	originalPersistentCommits["$commit"]=t
	originalPersistentRebasedCommits["$authorEpoch"$'\t'"$additionalIdentifyingInformation"]="$commit"
	if [ -v originalPersistentReworkedCommits["$additionalIdentifyingInformation"] ]; then
	    # The additional identifying information is not unique, so we cannot reliably
	    # identify reworked commits by it. Clear the mapping to prevent false positives.
	    originalPersistentReworkedCommits["$additionalIdentifyingInformation"]=''
	else
	    originalPersistentReworkedCommits["$additionalIdentifyingInformation"]="$commit"
	    lenientAdditionalIdentifyingInformation="$(getLenientIdentifyingInformation "$additionalIdentifyingInformation")" \
		&&  if [ -v originalPersistentReworkedLenientCommits["$lenientAdditionalIdentifyingInformation"] ]; then
			# The lenient additional identifying information is not unique, so we cannot
			# reliably identify reworked commits by it. Clear the mapping to prevent false
			# positives.
			originalPersistentReworkedLenientCommits["$lenientAdditionalIdentifyingInformation"]=''
		    else
			originalPersistentReworkedLenientCommits["$lenientAdditionalIdentifyingInformation"]="$commit"
		    fi
	fi
    done < "$originalPersistentCommitsFilespec"

    : > "$rebasedCommitHashesFilespec"
    for ((i = 0; i < ${#rebasedPersistentCommitList[@]}; i++))
    do
	local rebasedCommit="${rebasedPersistentCommitList[$i]}"

	# First unchanged commit means we're reached the end of the rebased commits.
	[ "${originalPersistentCommits["$rebasedCommit"]}" ] \
	    && break

	local originalCommit="${originalPersistentRebasedCommits["${rebasedPersistentRebasedKeys["$rebasedCommit"]}"]}"
	if [ -n "$originalCommit" ]; then
	    local whereFound=rebased
	else
	    # The rebased commit isn't found in the original list. Maybe it got replaced by
	    # a different commit with the same identifying information?
	    originalCommit="${originalPersistentReworkedCommits["${rebasedPersistentReworkedKeys["$rebasedCommit"]}"]}"
	    if [ -n "$originalCommit" ]; then
		local whereFound=reworked
	    elif originalCommit="${originalPersistentReworkedLenientCommits["${rebasedPersistentReworkedLenientKeys["$rebasedCommit"]}"]}"; then
		local whereFound='leniently reworked'
	    else
		# Nope, this commit is new and doesn't correspond to any original commit.
		case ",${DEBUG:-}," in *,git-rebase:rebasedCommitHashes,*) printf >&2 '%sgit-rebase (rebasedCommitHashes): %s is new\n' "$PS5" "$rebasedCommit";; esac
		continue
	    fi
	fi

	case ",${DEBUG:-}," in *,git-rebase:rebasedCommitHashes,*) printf >&2 '%sgit-rebase (rebasedCommitHashes): %s got %s to %s\n' "$PS5" "$originalCommit" "$whereFound" "$rebasedCommit";; esac
	printf '%s\t%s\n' "$originalCommit" "$rebasedCommit" >> "$rebasedCommitHashesFilespec"
    done

    [ -s "$rebasedCommitHashesFilespec" ]
}

isChecks=t
isSubmoduleUpdate=t
typeset -a rebaseArgs=()
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printUsage "$0"; exit 0;;

	--generate-rebased-commit-hashes)
			shift; generateRebasedCommitHashes; exit $?;;

	--no-color|--color=*)
			shift;;
	--color)	shift; shift;;
	--no-submodule-update)
			shift; isSubmoduleUpdate=;;
	--no-rebase-checks)
			shift; isChecks=;;

	--command|-c|-x)
			shift; addExec '' "${1:?}"; shift;;
	--exec)		shift
			if ! contains "$GIT_REBASE_EXEC_END" "$@"; then
			    # Also support the built-in --exec as well (though I prefer -c|--command).
			    addExec '' "${1:?}"; shift
			    continue
			fi

			cmd=
			while [ $# -gt 0 -a "$1" != "$GIT_REBASE_EXEC_END" ]
			do
			    printf -v quotedArg '%q' "$1"
			    cmd+="${cmd:+ }${quotedArg}"
			    shift
			done
			if [ $# -eq 0 ]; then
			    echo "ERROR: --exec command must be concluded with '${GIT_REBASE_EXEC_END}'"; echo; printUsage "$0"
			    exit 2
			fi >&2
			shift
			addExec t "$cmd"
			;;
	--check)	shift
			if [ -n "$GIT_REBASE_CHECK_COMMAND" ]; then
			    addExec '' "$GIT_REBASE_CHECK_COMMAND"
			elif [ -n "$GIT_CHECK_COMMAND" ]; then
			    addExec '' "$GIT_CHECK_COMMAND"
			else
			    echo >&2 'No checks to run.'
			    exit 1
			fi
			;;
	-)		shift
			checkCommands="$(</dev/stdin)"
			addExec '' "${checkCommands:?}"
			;;
	--)		shift
			if [ $# -gt 0 ]; then
			    printf -v quotedSimpleCommand ' %q' "$@"
			    addExec t "git-wrapper${quotedSimpleCommand}"
			    set --
			fi
			break
			;;
	*)		rebaseArgs+=("$1"); shift;;
    esac
done

[ ! "$isChecks" ] || git-rebasecheck "${rebaseArgs[@]}" "$@" || exit $?
git-isrebasing || recordOriginalPersistentCommits

eval "typeset -a gitConfigArgs=($GIT_CONFIG_ARGS)"
command git "${gitConfigArgs[@]}" rebase "${rebaseArgs[@]}" "$@" || exit $?

generateRebasedCommitHashes

[ "$isSubmoduleUpdate" ] || exit 0
readarray -t rebasedSubmodules < <(git subst)
[ ${#rebasedSubmodules[@]} -gt 0 ] || exit 0

if [ ${#rebasedSubmodules[@]} -eq 1 ]; then
    mergedSubmodulesArticle=This
    mergedSubmodulesAuxiliaryVerb=has
    mergedSubmodulesPlural=
else
    mergedSubmodulesArticle=These
    mergedSubmodulesAuxiliaryVerb=have
    mergedSubmodulesPlural=s
fi
printf '%s submodule%s %s been rebased; checking out the resulting version%s now: %s\n' "$mergedSubmodulesArticle" "$mergedSubmodulesPlural" "$mergedSubmodulesAuxiliaryVerb" "$mergedSubmodulesPlural" "$(joinBy --last-separator ' and ' ', ' "${rebasedSubmodules[@]}")"
git subwipe
