#!/bin/bash
set -o noglob

: ${GIT_SHOWFILESCOMMAND_REVISIONS_END=;}

printUsage()
{
    cat <<HELPTEXT
Execute GIT-COMMAND with the files (inside <pathspec>) that were modified in the
last commit / N'th commit / passed -r|--revision[s] REVISION(s).
- appended
- replacing FILES argument(s) anywhere
- replacing FILES in the following GIT-COMMAND and -(N-1) arguments
- replacing FILES in the following +(N) arguments and appending those
HELPTEXT
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" "[-c ...] GIT-COMMAND [-n N|--count N|-r|--revision REVISION|--revisions REVISION1 [...] $GIT_SHOWFILESCOMMAND_REVISIONS_END] [GIT-COMMAND-ARGS ...] [--] [<pathspec>...] [-?|-h|--help]"
    printf 'Usage: %q %s\n' "$(basename "$1")" "--keep-position GIT-COMMAND [-n N|--count N|-r|--revision REVISION|--revisions REVISION1 [...] $GIT_SHOWFILESCOMMAND_REVISIONS_END] [... FILES ...] [--] [<pathspec>...]"
    printf 'Usage: %q %s\n' "$(basename "$1")" "[-2 GIT-COMMAND ARG1|-3 GIT-COMMAND ARG1 ARG2|...] [-n N|--count N|-r|--revision REVISION|--revisions REVISION1 [...] $GIT_SHOWFILESCOMMAND_REVISIONS_END] [...] [--] [<pathspec>...]"
    printf 'Usage: %q %s\n' "$(basename "$1")" "[+1 ARG1|+2 ARG1 ARG2|+3 ARG1 ARG2 ARG3|...] GIT-COMMAND [-n N|--count N|-r|--revision REVISION|--revisions REVISION1 [...] $GIT_SHOWFILESCOMMAND_REVISIONS_END] [...] [--] [<pathspec>...]"
}

case "$1" in
    --help|-h|-\?)	shift; printUsage "$0"; exit 0;;
esac

typeset -a revisions=()
typeset -a args=()
unset files
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printUsage "$0"; exit 0;;
	--count|-n)	shift
			if ! [[ "$1" =~ ^[0-9]+$ ]]; then
			    printUsage "$0" >&2
			    exit 2
			fi
			revisions+=("HEAD~$(($1 - 1))")
			shift
			;;
	--revision|-r)	if [ ${#revisions[@]} -eq 0 ]; then
			    shift; revisions+=("${1:?}"); shift
			else
			    args+=("$1" "${2:?}"); shift; shift
			fi
			;;
	--revisions)	shift
			while [ $# -gt 0 -a "$1" != "$GIT_SHOWFILESCOMMAND_REVISIONS_END" ]
			do
			    revisions+=("${1:?}"); shift
			done
			if [ $# -eq 0 ]; then
			    echo "ERROR: --revisions must be concluded with '${GIT_SHOWFILESCOMMAND_REVISIONS_END}'"; echo; printUsage "$0"
			    exit 2
			fi >&2
			shift
			;;
	--)		shift; typeset -a files=("$@"); set --; break;;
	*)		args+=("$1"); shift;;
    esac
done
if [ -z "${files+t}" ]; then
    # No files after -- captured yet; need to investigate parsed and
    # remaining args from behind for files.
    typeset -a files=()
    args+=("$@")
    while [ ${#args[@]} -ne 0 ]
    do
	lastArg="${args[-1]}"
	[ -e "$lastArg" ] || break

	files=("$lastArg" "${files[@]}")
	args=("${args[@]:0:${#args[@]}-1}")
    done
fi
set -- "${args[@]}" "$@"
if [ $# -eq 0 ]; then
    echo >&2 'ERROR: No GIT-COMMAND passed.'
    exit 2
fi

readarray -t committedFiles < <(
    eval "${GIT_SHOWFILES_COMMAND:-git-showfiles}" '"${revisions[@]}" -- "${files[@]}"' \
	| { xargs -n 1 --no-run-if-empty sh -c 'test -r "$1" && printf %s\\n "$1"' sh || :; }
    printf '\n%d\n' ${PIPESTATUS[0]}
)	# Exit status from the process substitution is lost; return the actual exit status via an appended additional line.
[ ${committedFiles[-1]} -ne 0 ] && exit ${committedFiles[-1]}
unset "committedFiles[$((${#committedFiles[@]}-1))]"
[ -z "${committedFiles[-1]}" ] && unset "committedFiles[$((${#committedFiles[@]}-1))]"
[ ${#committedFiles[@]} -gt 0 ] || exit 99

isCountedAppend=
case "$1" in
    +[1-9])
	isCountedAppend=t;&
    -[1-9])
	typeset countedArgNum=${1#[+-]}
	typeset -a countedArgs=("${@:2:${countedArgNum}}")
	set -- "${@:$((2 + countedArgNum))}"

	typeset -a appendedArgs=()
	for arg in "${countedArgs[@]}"
	do
	    if [ "$arg" = 'FILES' ]; then
		appendedArgs+=("${committedFiles[@]}")
	    else
		appendedArgs+=("$arg")
	    fi
	done

	[ "$isCountedAppend" ] \
	    && exec git-wrapper "$@" "${appendedArgs[@]}" \
	    || exec git-wrapper "${appendedArgs[@]}" "$@"
	;;
    --keep-position)
	shift

	typeset -a appendedArgs=()
	for arg
	do
	    if [ "$arg" = 'FILES' ]; then
		appendedArgs+=("${committedFiles[@]}")
	    else
		appendedArgs+=("$arg")
	    fi
	done

	exec git-wrapper "${appendedArgs[@]}"
	;;
    *)
	exec git-wrapper "$@" -- "${committedFiles[@]}"
	;;
esac
