#!/bin/bash

printUsage()
{
    cat <<HELPTEXT
Test whether there are new files not yet added to version control (and not
covered by the ignore patterns) or files with an unstaged modification. Changes
in the index are ignored.
HELPTEXT
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" '[-p|--print [-E|--print-error [--error-message MSG]]] [--] [<pathspec>...] [-?|-h|--help]'
}

isPrint=
errorMessage='ERROR: Working copy has untracked and/or unstaged files:'
isPrintError=
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printUsage "$0"; exit 0;;
	--no-color|--color=*)
			shift;;
	--color)	shift; shift;;
	--print|-p)	shift; isPrint=t;;
	--)		shift; break;;
	-*)		{ echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2;;
	*)		break;;
    esac
done

untrackedFilespecs="$(git ls-files --modified --others --exclude-standard -- "$@" 2>/dev/null)"
[ -n "$untrackedFilespecs" ] || exit 1
if [ "$isPrint" ]; then
    [ ! "$isPrintError" ] || printf >&2 '%s\n' "$errorMessage"
    printf '%s\n' "$untrackedFilespecs"
    [ ! "$isPrintError" ] || exit 1
fi
