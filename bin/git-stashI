#!/bin/bash

printUsage()
{
    cat <<HELPTEXT
Save only the dirty working copy [within <pathspec>] in a commit; keep the index
untouched.
Useful to stash the working copy without doing a WIP commit for the index yet.

SEE ALSO:
- git-stashst includes the index in the stash, but also keeps those staged
  changes.
HELPTEXT
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" '[push] [-m|--message <message>] [--] [<pathspec>...] [-?|-h|--help]'
}

typeset -a stashArgs=()
unset files
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printUsage "$0"; exit 0;;
	--no-color|--color=*)
			shift;;
	--color)	shift; shift;;
	--)		shift; typeset -a files=("$@"); set --; break;;
	*)		stashArgs+=("$1"); shift;;
    esac
done
if [ -z "${files+t}" ]; then
    # No files after -- captured yet; need to investigate parsed and
    # remaining args from behind for files.
    typeset -a files=()
    stashArgs+=("$@")
    while [ ${#stashArgs[@]} -ne 0 ]
    do
	lastArg="${stashArgs[-1]}"
	[ -e "$lastArg" ] || break

	files=("$lastArg" "${files[@]}")
	stashArgs=("${stashArgs[@]:0:${#stashArgs[@]}-1}")
    done
fi

readarray -t stagedFiles < <(git-stifiles ${files:+--} "${files[@]}")
if [ ${#stagedFiles[@]} -eq 0 ]; then
    echo >&2 "Note: No staged files to keep${files:+ here}, just stashing the working copy."
    exec git-wrapper stash "${stashArgs[@]}" ${files:+--} "${files[@]}"
fi

git-swapstage --continue-command "$(basename "$0")" ${files:+--} "${files[@]}" || exit $?

git-stashi "${stashArgs[@]}" ${files:+--} "${files[@]}" \
    && git add -- "${stagedFiles[@]}"
