#!/bin/bash
set -o pipefail

printUsage()
{
    cat <<HELPTEXT
Drop the staged changes [compared to <commit>] from the working copy; i.e.
revert in the working copy those changes that have been added to the index but
not committed yet.
HELPTEXT
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" '[<commit>] [--] [<pathspec>...] [-?|-h|--help]'
}
case "$1" in
    --help|-h|-\?)	shift; printUsage "$0"; exit 0;;
    --no-color|--color=*)
			shift;;
    --color)		shift; shift;;
esac

git diff --no-color --cached "$@" | git apply --reverse
